  <entry>
    <title>[DotnetCore]SMTP寄信服務設計</title>
    <link href="https://eugenesu0515.github.io/2021/08/21/dotnetcore-smtp/"/>
    <id>https://eugenesu0515.github.io/2021/08/21/dotnetcore-smtp/</id>
